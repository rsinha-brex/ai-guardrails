# AI Guardrails — env var template (copy to .env)

# Postgres connection (pooler for app, direct for migrations)
DATABASE_URL=postgresql://USER:PASS@HOST:6543/DBNAME
DIRECT_URL=postgresql://USER:PASS@HOST:5432/DBNAME

# Supabase project (only used by frontend if it ever talks directly)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# LLM gateway
OPENROUTER_API_KEY=
MAIN_MODEL=anthropic/claude-sonnet-4.5
COMPILE_MODEL=anthropic/claude-sonnet-4.5
JUDGE_MODEL=anthropic/claude-haiku-4.5

# HTTP Basic Auth on backend /api/*
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=guardrails

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
